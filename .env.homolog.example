# Exemplo de .env para HOMOLOGAÇÃO na plataforma da Missão.
# Copie para .env.homolog e preencha com os valores reais fornecidos pela infra.
# Uso: docker compose -f docker-compose.prod.yml --env-file .env.homolog up -d

# ── Banco de dados ──────────────────────────────────────────────────────────
# Postgres compartilhado da plataforma (container na missao-network).
# A infra fornece host/usuário/senha/database para homolog.
DATABASE_URL=postgresql://USUARIO:SENHA@postgres:5432/news_radar_homolog

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Bot DIFERENTE do de produção — criar via @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scheduler interno ────────────────────────────────────────────────────────
# 0 = desativado. Em homolog/prod o N8N é quem agenda as coletas.
NEWS_RADAR_SCHEDULER=0
NEWS_RADAR_DISPATCH_TOP=3
NEWS_RADAR_DISPATCH_SCOPE=piaui

# ── N8N compartilhado ────────────────────────────────────────────────────────
# URL pública do N8N de homolog (provido pela infra).
N8N_WEBHOOK_URL=https://n8n-homolog.seudominio.com.br/

# ── URLs públicas ────────────────────────────────────────────────────────────
DOMAIN=news-radar-homolog.seudominio.com.br
NEWS_RADAR_PUBLIC_URL=https://news-radar-homolog.seudominio.com.br
NEWS_RADAR_API_URL=http://app:8888
