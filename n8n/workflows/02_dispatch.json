      "position": [0, 400]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "30 17 * * *"
            }
          ]
        }
      },
      "id": "sched-evening",
      "name": "⏰ 17:30 Tarde",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 600]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.NEWS_RADAR_API }}/api/dispatch/run",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"edition\": \"morning\",\n  \"scope\": \"{{ $vars.NEWS_RADAR_SCOPE }}\",\n  \"top\": 3,\n  \"dry_run\": false\n}",
        "options": {}
      },
      "id": "dispatch-morning",
      "name": "Dispatch Manhã",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.NEWS_RADAR_API }}/api/dispatch/run",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"edition\": \"noon\",\n  \"scope\": \"{{ $vars.NEWS_RADAR_SCOPE }}\",\n  \"top\": 3,\n  \"dry_run\": false\n}",
        "options": {}
      },
      "id": "dispatch-noon",
      "name": "Dispatch Meio-dia",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.NEWS_RADAR_API }}/api/dispatch/run",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"edition\": \"evening\",\n  \"scope\": \"{{ $vars.NEWS_RADAR_SCOPE }}\",\n  \"top\": 3,\n  \"dry_run\": false\n}",
        "options": {}
      },
      "id": "dispatch-evening",
      "name": "Dispatch Tarde",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, 600]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "ok-check-morning",
              "leftValue": "={{ $json.ok }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-morning",
      "name": "Manhã falhou?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [560, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "ok-check-noon",
              "leftValue": "={{ $json.ok }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-noon",
      "name": "Meio-dia falhou?",
