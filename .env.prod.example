# Exemplo de .env para PRODUÇÃO na plataforma da Missão.
# Copie para .env.prod e preencha com os valores reais fornecidos pela infra.
# Uso: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ── Banco de dados ──────────────────────────────────────────────────────────
# Postgres compartilhado da plataforma (container na missao-network).
DATABASE_URL=postgresql://USUARIO:SENHA@postgres:5432/news_radar

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Bot de PRODUÇÃO — criar via @BotFather, diferente do bot de homolog.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scheduler interno ────────────────────────────────────────────────────────
# 0 = desativado. Em homolog/prod o N8N é quem agenda as coletas.
NEWS_RADAR_SCHEDULER=0
NEWS_RADAR_DISPATCH_TOP=3
NEWS_RADAR_DISPATCH_SCOPE=piaui

# ── N8N compartilhado ────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.seudominio.com.br/

# ── URLs públicas ────────────────────────────────────────────────────────────
DOMAIN=news-radar.seudominio.com.br
NEWS_RADAR_PUBLIC_URL=https://news-radar.seudominio.com.br
NEWS_RADAR_API_URL=http://app:8888
