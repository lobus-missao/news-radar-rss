# ── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://news:senha@localhost:5432/news_radar

# PostgreSQL (Docker)
POSTGRES_USER=news
POSTGRES_PASSWORD=senha_segura_aqui

# ── Telegram Bot (usado pelo workflow editorial) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scheduler interno ────────────────────────────────────────────────────────
# 0 = desativado (padrão) — n8n é o scheduler externo
# 1 = ativado — APScheduler interno assume coleta automática
NEWS_RADAR_SCHEDULER=0
NEWS_RADAR_DISPATCH_TOP=3
NEWS_RADAR_DISPATCH_SCOPE=piaui

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=senha_n8n_segura

# Webhook outbound: ingestion notifica o n8n ao terminar `collect_feeds`.
# Vazio = modelo pull (n8n consulta a API). Definido = modelo push (event-driven).
N8N_WEBHOOK_URL=

# ── Servidor (produção) ──────────────────────────────────────────────────────
# Domínio real apontando para o servidor (Caddy gera HTTPS automático)
DOMAIN=news.seudominio.com.br

# URL da API Python (usada pelo n8n via variável de ambiente)
NEWS_RADAR_API_URL=http://app:8888
