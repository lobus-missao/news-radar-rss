# ── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://news:senha@localhost:5432/news_radar

# PostgreSQL (Docker)
POSTGRES_USER=news
POSTGRES_PASSWORD=senha_segura_aqui

# ── Ollama (IA local — roda no HOST, não no container) ──────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Crie o bot em @BotFather e revogue o token antigo se compartilhou publicamente
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=senha_n8n_segura

# ── Servidor (producao) ───────────────────────────────────────────────────────
# Dominio real apontando para o servidor (Caddy gera HTTPS automatico)
DOMAIN=news.seudominio.com.br

# URL da API Python (usada pelo n8n via variavel de ambiente)
# Docker producao: http://app:8888
# Dev local:       http://localhost:8888
NEWS_RADAR_API_URL=http://app:8888
