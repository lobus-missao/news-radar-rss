# Exemplo de .env para DEV LOCAL.
# Copie para .env e ajuste os valores.
#
# Há 2 composes:
# - docker-compose.yml         → dev local (sobe postgres/n8n/searxng/cloudflared neste arquivo)
# - docker-compose.prod.yml    → homolog/prod na plataforma (conecta na missao-network;
#                                postgres e n8n vêm de fora). Ver .env.homolog.example
#                                e .env.prod.example.

# ── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://news:senha_local@postgres:5432/news_radar
POSTGRES_USER=news
POSTGRES_PASSWORD=senha_local

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Bot criado via @BotFather (use bot diferente em homolog/prod!).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scheduler interno ────────────────────────────────────────────────────────
# 1 = APScheduler interno (recomendado em dev)
# 0 = desativado (em homolog/prod o N8N agenda)
NEWS_RADAR_SCHEDULER=1
NEWS_RADAR_DISPATCH_TOP=3
NEWS_RADAR_DISPATCH_SCOPE=piaui

# ── N8N (container local do compose) ─────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=senha_n8n
N8N_WEBHOOK_URL=
N8N_HOST=

# ── URLs públicas ────────────────────────────────────────────────────────────
DOMAIN=localhost
NEWS_RADAR_PUBLIC_URL=
NEWS_RADAR_API_URL=http://app:8888

# ── SearXNG ──────────────────────────────────────────────────────────────────
SEARXNG_URL=http://searxng:8080
